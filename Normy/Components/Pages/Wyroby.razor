@page "/wyroby"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IJSRuntime JS
@using System.Linq
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@attribute [Authorize(Roles = "Administrator,Technolog")]
@using Microsoft.AspNetCore.Authorization
@using Normy.Data
@using Normy.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory


<h3>Wyroby</h3>

<h4>Dodaj wyrób</h4>

<div class="row">
    <div class="col-md-4 mb-3">
        <label>Nr wyrobu</label>
        <input class="form-control" @bind="nowyNumerWyrobu" />
    </div>

    <div class="col-md-4 mb-3">
        <label>Nr operacji</label>
        <input class="form-control" @bind="nowyNumerOperacji" />
    </div>

    <div class="col-md-4 mb-3">
        <label>Nr maszyny</label>
        <input class="form-control" @bind="nowyNumerMaszyny" />
    </div>
</div>

<button class="btn btn-success" @onclick="DodajWyrob">
    Dodaj wyrób
</button>

<hr />

<h4>Wyszukiwanie i filtrowanie</h4>

<div class="row">
    <div class="col-md-4 mb-3">
        <label>Szukaj</label>
        <input class="form-control"
               placeholder="Nr wyrobu, operacja, maszyna..."
               @bind="tekstSzukania"
               @bind:event="oninput" />
    </div>

    <div class="col-md-3 mb-3">
        <label>Status</label>
        <select class="form-select" @bind="wybranyStatus">
            <option value="">Wszystkie</option>
            <option value="W trakcie">W trakcie</option>
            <option value="Do przeliczenia">Do przeliczenia</option>
            <option value="Wyliczona norma">Wyliczona norma</option>
            <option value="Zatwierdzona">Zatwierdzona</option>
            <option value="Archiwalna">Archiwalna</option>
        </select>
    </div>
</div>

<h4>Lista wyrobów</h4>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nr wyrobu</th>
            <th>Operacja</th>
            <th>Maszyna</th>
            <th>Status</th>
            <th>Norma (szt./zmianę)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var wyrob in FiltrowaneWyroby)
        {
            <tr>
                <td>@wyrob.NumerWyrobu</td>
                <td>@wyrob.NumerOperacji</td>
                <td>@wyrob.NumerMaszyny</td>
                <td>@wyrob.Status</td>
                <td>@wyrob.WyliczonaNorma</td>
                <td>
                    <button class="btn btn-primary btn-sm"
                            @onclick="() => OtworzWyrob(wyrob)">
                    Otwórz
                    </button>
                    <button class="btn btn-danger btn-sm"
                            @onclick="() => UsunWyrob(wyrob)">
                        Usuń
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private string nowyNumerWyrobu = "";
    private string nowyNumerOperacji = "";
    private string nowyNumerMaszyny = "";

    private string tekstSzukania = "";
    private string wybranyStatus = "";

    private List<Wyrob> wyroby = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        wyroby = await db.Wyroby
            .AsNoTracking()
            .OrderBy(w => w.NumerWyrobu)
            .ToListAsync();
    }

    private IEnumerable<Wyrob> FiltrowaneWyroby =>
        wyroby.Where(w =>
            (string.IsNullOrWhiteSpace(tekstSzukania)
             || w.NumerWyrobu.Contains(tekstSzukania, StringComparison.OrdinalIgnoreCase)
             || w.NumerOperacji.Contains(tekstSzukania, StringComparison.OrdinalIgnoreCase)
             || w.NumerMaszyny.Contains(tekstSzukania, StringComparison.OrdinalIgnoreCase))
            &&
            (string.IsNullOrWhiteSpace(wybranyStatus)
             || w.Status == wybranyStatus));

    private async Task DodajWyrob()
    {
        if (string.IsNullOrWhiteSpace(nowyNumerWyrobu)
            || string.IsNullOrWhiteSpace(nowyNumerOperacji)
            || string.IsNullOrWhiteSpace(nowyNumerMaszyny))
        {
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        var nowy = new Wyrob
        {
            NumerWyrobu = nowyNumerWyrobu.Trim(),
            NumerOperacji = nowyNumerOperacji.Trim(),
            NumerMaszyny = nowyNumerMaszyny.Trim(),
            Status = "W trakcie"
        };

        db.Wyroby.Add(nowy);
        await db.SaveChangesAsync();

        wyroby.Add(nowy);

        nowyNumerWyrobu = "";
        nowyNumerOperacji = "";
        nowyNumerMaszyny = "";
    }

    private void OtworzWyrob(Wyrob wyrob)
    {
        Nav.NavigateTo($"/wyrob/{wyrob.Id}");
    }

    private async Task UsunWyrob(Wyrob wyrob)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var rekord = await db.Wyroby.FindAsync(wyrob.Id);

        if (rekord is not null)
        {
            db.Wyroby.Remove(rekord);
            await db.SaveChangesAsync();

            wyroby.Remove(wyrob);
        }
    }

}